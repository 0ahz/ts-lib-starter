{
  "name": "ts-lib-starter",
  "version": "0.0.3",
  "description": "Typescript library starter",
  "repository": "0ahz/ts-lib-starter",
  "license": "MIT",
  "author": "Mark1 <shuangoahz@gmail.com> (https://github.com/0ahz)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "dist/tslibstarter.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./sub": {
      "types": "./dist/sub/index.d.ts",
      "require": "./dist/sub/index.cjs",
      "import": "./dist/sub/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "sub": [
        "./dist/sub/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:index": "vitest run  test/*.spec.ts",
    "test:sub": "vitest run --dir test/sub",
    "lint": "eslint ./src",
    "format": "prettier --write src",
    "dev:tsdown": "tsdown --watch",
    "dev:rollup": "rollup -c --watch",
    "dev:vue": "pnpm -F playground-vue run dev",
    "dev": "run-p dev:tsdown dev:rollup",
    "build:tsdown": "tsdown",
    "build:rollup": "rollup -c",
    "build": "pnpm build:tsdown && pnpm build:rollup",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "release:publish": "pnpm release && pnpm publish --registry https://registry.npmjs.org/",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@0ahz/prettier-config": "^1.0.0",
    "@rollup/plugin-commonjs": "^29.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "bumpp": "^10.4.1",
    "camelcase": "^9.0.0",
    "changelogen": "^0.6.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-config-unjs": "^0.6.2",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --list-different --write",
      "eslint"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
